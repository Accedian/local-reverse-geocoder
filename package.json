{
  "name": "local-reverse-geocoder",
  "version": "0.14.0",
  "private": true,
  "packageManager": "pnpm@10.17.0",
  "description": "Implements a local reverse geocoder based on GeoNames.",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "lint": "jshint --exclude ./node_modules,./docs/scripts .",
    "start": "node --max-old-space-size=4096 app.js",
    "test": "node --test --test-force-exit",
    "prebake": "node --max-old-space-size=4096 prebake.js",
    "validate:network": "node validation/validate-network.mjs",
    "build": "jsdoc -d docs index.js",
    "prettier": "prettier --write *.{js,md,json}"
  },
  "keywords": [
    "geocoding",
    "geocoder",
    "reverse",
    "local"
  ],
  "files": [
    "app.js",
    "prebake.js",
    "index.js",
    "index.d.ts"
  ],
  "author": "Thomas Steiner",
  "license": "Apache-2.0",
  "dependencies": {
    "async": "3.2.4",
    "csv-parse": "5.3.2",
    "kdt": "0.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tomayac/local-reverse-geocoder.git"
  },
  "bugs": {
    "url": "https://github.com/tomayac/local-reverse-geocoder/issues"
  },
  "homepage": "https://github.com/tomayac/local-reverse-geocoder",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/cors": "2.8.12",
    "@types/express": "4.17.14",
    "@types/node": "18.11.9",
    "cors": "2.8.5",
    "express": "4.19.2",
    "jsdoc": "4.0.0",
    "jshint": "2.13.6",
    "prettier": "2.8.0"
  }
}